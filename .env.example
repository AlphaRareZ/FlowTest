# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  FlowTest – Environment Configuration                                     ║
# ║                                                                            ║
# ║  Copy this file to .env and fill in your values:                           ║
# ║    cp .env.example .env                                                    ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ── Public URL ────────────────────────────────────────────────────────────────
# Replace YOUR_VPS_IP with your server's public IP or domain name.
# This gets baked into the Next.js build, so you must rebuild after changing it.

NEXT_PUBLIC_API_URL=http://YOUR_VPS_IP:3001/api

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins

CORS_ORIGINS=http://YOUR_VPS_IP:3000

# ── Ports (optional – change only if you have conflicts) ─────────────────────

FRONTEND_PORT=3000
BACKEND_PORT=3001

# ── Simulation Limits (optional) ─────────────────────────────────────────────

MAX_CONCURRENT_USERS=1000
HTTP_REQUEST_TIMEOUT_MS=10000
MAX_RETRIES=2
